# Copy to .env and fill in. .env is git-ignored — NEVER commit real secrets.

# --- Database (Postgres 16 + TimescaleDB, via docker-compose) ---
DATABASE_URL=postgres://swing:swing@localhost:5433/swing
PGHOST=localhost
PGPORT=5433
PGUSER=swing
PGPASSWORD=swing
PGDATABASE=swing

# --- Python ML worker ---
ML_WORKER_URL=http://localhost:8088

# --- Market data providers ---
# Financial Modeling Prep (https://financialmodelingprep.com) — primary provider.
FMP_API_KEY=__set_me__
FMP_BASE_URL=https://financialmodelingprep.com/stable
# FRED (https://fred.stlouisfed.org) — free, for credit spreads + net liquidity. Optional.
FRED_API_KEY=

# --- API server ---
SE_API_BIND=0.0.0.0:8080
RUST_LOG=info,se_=debug

# --- Active horizon profile (swing | short_swing | day | zero_dte | scalp) ---
SE_HORIZON=swing
